---
import Layout from "./_Layout.astro";

const boardSquares = Array.from({ length: 64 });

const features = [
  {
    title: "Play online",
    text: "Find a live game, pick a time control, and play Sovereign Chess with other players.",
    href: "/play",
    status: "Stubbed",
  },
  {
    title: "Analysis board",
    text: "Explore positions, replay lines, and inspect move ideas without starting a game.",
    href: "/analysis",
    status: "Stubbed",
  },
  {
    title: "Board editor",
    text: "Set up positions on the current board implementation and prepare custom scenarios.",
    href: "/editor",
    status: "Active shell",
  },
];
---

<Layout title="Open Sovereign Chess">
  <section class="home-hero">
    <div class="site-inner home-hero__grid">
      <div class="home-hero__copy">
        <p class="eyebrow">Sovereign Chess online</p>
        <h1>Play, study, and build positions for Sovereign Chess.</h1>
        <p>
          A web home for learning the variant, exploring the board, and
          eventually playing live games with other people.
        </p>
        <div class="button-row">
          <a class="button primary" href="/editor">Open board editor</a>
          <a class="button" href="/rules">Learn the rules</a>
        </div>
      </div>
      <div class="home-board" aria-hidden="true">
        <div class="stub-board">
          {boardSquares.map(() => <span />)}
        </div>
      </div>
    </div>
  </section>

  <section class="site-section">
    <div class="site-inner">
      <div class="section-heading">
        <p class="eyebrow">What is here</p>
        <h2>Core areas</h2>
      </div>
      <div class="feature-grid">
        {
          features.map((feature) => (
            <a class="feature-card" href={feature.href}>
              <span>{feature.status}</span>
              <h3>{feature.title}</h3>
              <p>{feature.text}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="site-section rules-band">
    <div class="site-inner rules-band__grid">
      <div>
        <p class="eyebrow">Game rules</p>
        <h2>Learn the variant before jumping into the tools.</h2>
      </div>
      <div>
        <p>
          Sovereign Chess changes how piece ownership and board regions work, so
          the homepage should make the learning path visible before asking
          people to play.
        </p>
        <div class="button-row">
          <a class="button primary" href="/rules">Read the site overview</a>
          <a
            class="button"
            href="https://www.infinitepigames.com/sovereign-chess"
          >
            Official game site
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-hero {
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    padding: clamp(28px, 6vw, 72px) clamp(16px, 4vw, 56px);
  }

  .home-hero__grid {
    display: grid;
    align-items: center;
    gap: clamp(28px, 6vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 460px);
  }

  .home-hero__copy h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .home-hero__copy p:not(.eyebrow) {
    max-width: 620px;
    margin: 18px 0 24px;
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .home-board {
    display: flex;
    justify-content: center;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 18px;
  }

  .section-heading h2,
  .rules-band h2 {
    margin: 0;
    font-size: clamp(1.7rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .feature-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-card {
    min-height: 230px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
    background: var(--surface-strong);
    color: inherit;
    text-decoration: none;
  }

  .feature-card:hover,
  .feature-card:focus-visible {
    border-color: var(--primary);
    outline: none;
  }

  .feature-card span {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .feature-card h3 {
    margin: 42px 0 10px;
    font-size: 1.45rem;
  }

  .feature-card p,
  .rules-band p {
    color: var(--muted);
    line-height: 1.58;
  }

  .rules-band {
    background: #ece7da;
  }

  .rules-band__grid {
    display: grid;
    align-items: start;
    gap: 32px;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }

  .rules-band .button-row {
    margin-top: 20px;
  }

  @media (max-width: 860px) {
    .home-hero__grid,
    .rules-band__grid {
      grid-template-columns: 1fr;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .home-board {
      justify-content: flex-start;
    }
  }
</style>
