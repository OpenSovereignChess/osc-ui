---
import Layout from "./_Layout.astro";
import AnalysisBoard from "../game/analysis/AnalysisBoard.tsx";
---

<Layout title="Analysis | Open Sovereign Chess">
  <section class="tool-shell">
    <aside class="tool-panel">
      <p class="eyebrow">Analysis</p>
      <h1>Analysis board</h1>
      <p>
        Select a piece to inspect its legal moves from the starting position.
      </p>
      <div class="button-row">
        <a class="button" href="/editor/">Set up board</a>
        <a class="button disabled" aria-disabled="true">Import PGN</a>
      </div>
    </aside>
    <div class="tool-stage">
      <div class="analysis-board">
        <AnalysisBoard client:only="solid-js" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .analysis-board {
    width: min(100%, calc(100vh - 220px));
    min-width: 280px;
    min-height: 280px;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  @media (max-width: 760px) {
    .analysis-board {
      width: min(100%, calc(100vh - 260px));
    }
  }
</style>
